# Kala Jawi Dashboard - Environment Configuration

# ============= SUPABASE CONFIGURATION =============
# Get these values from your Supabase project settings
# https://supabase.com/dashboard

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public key for client-side)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============= DEVELOPMENT =============
# Set to true to enable mock mode (for development without real Supabase)
# When false, will use real Supabase connection
VITE_USE_MOCK=false

# ============= DEPLOYMENT =============
# Cloudflare Workers Configuration (if deploying to Cloudflare)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
